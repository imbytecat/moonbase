{
  "name": "@moonbase/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#messages/*": "./messages/*",
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:routes": "tsr generate",
    "gen:i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy localStorage preferredLanguage baseLocale",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.3.2",
    "@ant-design/plots": "^2.6.8",
    "@bufbuild/protobuf": "catalog:",
    "@connectrpc/connect": "catalog:",
    "@connectrpc/connect-query": "catalog:",
    "@connectrpc/connect-web": "catalog:",
    "@dagrejs/dagre": "^3.0.0",
    "@marsidev/react-turnstile": "^1.5.3",
    "@moonbase/api-client": "workspace:*",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@xyflow/react": "^12.11.2",
    "altcha": "^2.3.0",
    "antd": "^6.5.0",
    "antd-phone-input": "^0.3.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-geetest-v4": "^1.2.0",
    "react-phone-hooks": "^0.1.22"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@inlang/paraglide-js": "^2.20.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.18",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
